{
  "name": "@surrounded-by-slop/cli",
  "version": "0.0.1",
  "description": "Headless code analysis for AI agents and CI — the Surrounded by Slop semantic graph from the terminal.",
  "repository": {
    "type": "git",
    "url": "https://github.com/georgyia/surrounded-by-slop.git",
    "directory": "packages/cli"
  },
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "bin": {
    "sbs": "./dist/bin.js"
  },
  "files": [
    "dist/**/*.js",
    "dist/**/*.d.ts",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=20.19"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "build": "node esbuild.mjs && tsc -p tsconfig.build.json --emitDeclarationOnly",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@surrounded-by-slop/core": "workspace:*",
    "typescript": "^5.9.3"
  },
  "devDependencies": {
    "@surrounded-by-slop/host": "workspace:*",
    "@types/node": "^26.1.1",
    "esbuild": "^0.28.1"
  }
}
