{
  "name": "surrounded-by-slop",
  "displayName": "Surrounded by Slop",
  "version": "0.0.1",
  "private": true,
  "description": "See the code you'll never read — automatic diagrams for your codebase.",
  "publisher": "georgyia",
  "repository": {
    "type": "git",
    "url": "https://github.com/georgyia/surrounded-by-slop.git",
    "directory": "packages/extension"
  },
  "license": "MIT",
  "engines": {
    "vscode": "^1.96.0"
  },
  "categories": [
    "Visualization"
  ],
  "keywords": [
    "diagram",
    "visualization",
    "architecture",
    "call graph",
    "drawio",
    "mermaid"
  ],
  "main": "./dist/extension.js",
  "activationEvents": [],
  "contributes": {
    "commands": [
      {
        "command": "slop.visualizeFile",
        "title": "Visualize File",
        "category": "Slop",
        "icon": "media/slop.svg"
      },
      {
        "command": "slop.visualizeFunctionFlow",
        "title": "Visualize Function Flow",
        "category": "Slop"
      },
      {
        "command": "slop.visualizeWorkspace",
        "title": "Visualize Workspace",
        "category": "Slop"
      },
      {
        "command": "slop.togglePin",
        "title": "Pin Diagram",
        "category": "Slop"
      },
      {
        "command": "slop.followActiveEditor",
        "title": "Follow Active Editor",
        "category": "Slop"
      },
      {
        "command": "slop.exportDiagram",
        "title": "Export Diagram As…",
        "category": "Slop"
      },
      {
        "command": "slop.copyMermaid",
        "title": "Copy Diagram as Mermaid",
        "category": "Slop"
      }
    ],
    "menus": {
      "editor/title": [
        {
          "command": "slop.visualizeFile",
          "when": "resourceLangId =~ /typescript|javascript/",
          "group": "navigation"
        }
      ],
      "editor/context": [
        {
          "command": "slop.visualizeFile",
          "when": "resourceLangId =~ /typescript|javascript/",
          "group": "navigation"
        },
        {
          "command": "slop.visualizeFunctionFlow",
          "when": "resourceLangId =~ /typescript|javascript/",
          "group": "navigation"
        }
      ],
      "commandPalette": [
        {
          "command": "slop.exportDiagram",
          "when": "slop.hasDiagram"
        },
        {
          "command": "slop.copyMermaid",
          "when": "slop.hasDiagram"
        },
        {
          "command": "slop.togglePin",
          "when": "slop.hasDiagram"
        }
      ]
    },
    "keybindings": [
      {
        "command": "slop.visualizeFile",
        "key": "ctrl+shift+v",
        "mac": "cmd+shift+v",
        "when": "editorTextFocus && editorLangId =~ /typescript|javascript/"
      }
    ],
    "configuration": {
      "title": "Surrounded by Slop",
      "properties": {
        "slop.include": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [
            "**/*.{ts,tsx,mts,cts,js,jsx,mjs,cjs}"
          ],
          "description": "Glob patterns for files to include when visualizing the workspace."
        },
        "slop.exclude": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [
            "**/node_modules/**",
            "**/dist/**",
            "**/out/**",
            "**/build/**",
            "**/coverage/**"
          ],
          "description": "Glob patterns to exclude when visualizing the workspace."
        },
        "slop.includeTests": {
          "type": "boolean",
          "default": false,
          "description": "Include test files (*.test.*, *.spec.*) in the workspace map."
        },
        "slop.showExternalModules": {
          "type": "boolean",
          "default": true,
          "description": "Show external packages and unresolved imports as nodes."
        },
        "slop.theme": {
          "type": "string",
          "enum": [
            "auto",
            "light",
            "dark"
          ],
          "enumDescriptions": [
            "Follow the editor theme",
            "Always light",
            "Always dark"
          ],
          "default": "auto",
          "description": "Diagram color theme."
        },
        "slop.layoutDirection": {
          "type": "string",
          "enum": [
            "right",
            "down"
          ],
          "enumDescriptions": [
            "Left to right",
            "Top to bottom"
          ],
          "default": "right",
          "description": "Direction the diagram layout flows."
        }
      }
    }
  },
  "scripts": {
    "build": "node esbuild.mjs",
    "watch": "node esbuild.mjs --watch",
    "typecheck": "tsc --noEmit",
    "test:integration": "node esbuild.mjs && node esbuild.test.mjs && node dist/test/runTest.js",
    "package": "pnpm run build --production && vsce package --no-dependencies -o surrounded-by-slop.vsix"
  },
  "dependencies": {
    "@surrounded-by-slop/core": "workspace:*",
    "@surrounded-by-slop/webview": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "@types/vscode": "^1.96.0",
    "@vscode/test-electron": "^2.4.1",
    "@vscode/vsce": "^3.3.0",
    "esbuild": "^0.28.1",
    "ovsx": "^1.0.2",
    "typescript": "^5.8.0"
  }
}
