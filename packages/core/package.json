{
  "name": "@surrounded-by-slop/core",
  "version": "0.0.1",
  "description": "Language-agnostic code analysis: source → Semantic Graph IR → exporters. Pure TypeScript, no editor dependencies.",
  "repository": {
    "type": "git",
    "url": "https://github.com/georgyia/surrounded-by-slop.git",
    "directory": "packages/core"
  },
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "sideEffects": false,
  "files": [
    "dist/**/*.js",
    "dist/**/*.d.ts",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=20.19"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@vscode/tree-sitter-wasm": "0.3.1",
    "elkjs": "^0.11.1",
    "typescript": "^5.9.3",
    "web-tree-sitter": "0.26.11"
  },
  "devDependencies": {
    "@types/node": "^26.1.1"
  }
}
