{
  "name": "@surrounded-by-slop/monorepo",
  "version": "0.0.0",
  "private": true,
  "description": "See the code you'll never read — automatic diagrams for your codebase.",
  "repository": {
    "type": "git",
    "url": "https://github.com/georgyia/surrounded-by-slop.git"
  },
  "license": "MIT",
  "packageManager": "pnpm@10.18.2",
  "engines": {
    "node": ">=20.19"
  },
  "scripts": {
    "build": "pnpm -r run build",
    "typecheck": "pnpm -r run typecheck",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "test": "vitest run --coverage",
    "test:watch": "vitest",
    "package": "pnpm --filter surrounded-by-slop run package",
    "changeset": "changeset",
    "bench": "pnpm --filter @surrounded-by-slop/core build && node scripts/bench.mjs",
    "docs:diagrams": "pnpm --filter @surrounded-by-slop/core build && node scripts/architecture-diagrams.mjs"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.0.0",
    "@changesets/cli": "^2.29.0",
    "@vitest/coverage-v8": "^3.2.0",
    "happy-dom": "^20.10.6",
    "typescript": "^7.0.2",
    "vitest": "^3.2.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@vscode/vsce-sign",
      "esbuild",
      "keytar"
    ]
  }
}
